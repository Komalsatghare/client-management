<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Join Zoom Meeting | <%= brandName %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

        :root {
            --primary: #2563eb;
            --secondary: #7c3aed;
            --accent: #10b981;
            --bg: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.7);
            --text: #f8fafc;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: radial-gradient(circle at top left, #1e1b4b, #0f172a 60%), #000;
            color: var(--text);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
        }

        /* ── Animated Background ── */
        .bg-glow {
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(37, 99, 235, 0.15), transparent 70%);
            z-index: -1;
            filter: blur(80px);
            animation: move 20s infinite alternate;
        }
        @keyframes move {
            from { transform: translate(-10%, -10%); }
            to { transform: translate(10%, 10%); }
        }

        .container {
            width: 100%;
            max-width: 500px;
            padding: 20px;
            box-sizing: border-box;
            z-index: 10;
        }

        /* ── Glass Card ── */
        .card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            text-align: center;
            animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .logo-area {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-bottom: 30px;
        }
        .logo-z {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-family: 'Orbitron', sans-serif;
            font-weight: 900;
            color: #fff;
            box-shadow: 0 8px 16px rgba(37, 99, 235, 0.3);
        }
        .brand-text {
            font-family: 'Orbitron', sans-serif;
            font-size: 18px;
            letter-spacing: 2px;
            font-weight: 700;
            color: #fff;
        }

        h2 {
            margin: 0 0 8px;
            font-size: 28px;
            font-weight: 800;
            background: linear-gradient(to right, #fff, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .topic-badge {
            display: inline-block;
            padding: 4px 12px;
            background: rgba(37, 99, 235, 0.1);
            border: 1px solid rgba(37, 99, 235, 0.3);
            border-radius: 99px;
            font-size: 12px;
            color: #93c5fd;
            font-weight: 700;
            margin-bottom: 24px;
        }

        .subtitle {
            font-size: 14px;
            color: #94a3b8;
            margin-bottom: 32px;
            line-height: 1.6;
        }

        /* ── Buttons ── */
        .btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            padding: 16px 24px;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none;
            width: 100%;
            box-sizing: border-box;
            border: none;
            margin-bottom: 16px;
        }

        .btn-app {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            color: #fff;
            box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.3);
        }
        .btn-app:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(37, 99, 235, 0.4);
            filter: brightness(1.1);
        }
        .btn-app:active { transform: translateY(0); }

        .btn-browser {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #e2e8f0;
        }
        .btn-browser:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(255, 255, 255, 0.2);
            color: #fff;
        }

        /* ── Divider ── */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 24px 0;
            color: #475569;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .divider::before, .divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: rgba(255, 255, 255, 0.05);
        }

        /* ── Info Box ── */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        .info-box {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 12px;
            position: relative;
            cursor: pointer;
            transition: border-color 0.2s;
        }
        .info-box:hover { border-color: rgba(255, 255, 255, 0.2); }
        .info-label {
            font-size: 10px;
            color: #64748b;
            font-weight: 800;
            text-transform: uppercase;
            margin-bottom: 4px;
            display: block;
        }
        .info-value {
            font-size: 14px;
            font-weight: 700;
            color: #fff;
            font-family: monospace;
        }
        .copy-icon {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 12px;
            color: #475569;
        }

        .footer {
            margin-top: 32px;
            font-size: 12px;
            color: #475569;
        }
        .footer i { color: var(--accent); margin-right: 4px; }

        /* ── Tooltip ── */
        .tooltip {
            position: absolute;
            bottom: 110%;
            left: 50%;
            transform: translateX(-50%);
            background: #10b981;
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 10px;
            font-weight: 800;
            opacity: 0;
            transition: opacity 0.3s;
            pointer-events: none;
        }
        .copied .tooltip { opacity: 1; }

        @media (max-width: 480px) {
            .card { padding: 30px 20px; }
            h2 { font-size: 24px; }
        }
    </style>
</head>
<body>
    <div class="bg-glow"></div>
    
    <div class="container">
        <div class="card">
            <div class="logo-area">
                <div class="logo-z">Z</div>
                <div class="brand-text"><%= brandName %></div>
            </div>

            <div class="topic-badge">PROJECT DISCUSSION</div>
            <h2>Join Meeting</h2>
            <div class="subtitle">
                Welcome, <strong><%= userName %></strong>.<br>
                Choose how you'd like to join the session for:<br>
                <span style="color: #fff; font-weight: 600;"><%= topic %></span>
            </div>

            <!-- PRIMARY ACTION: ZOOM APP -->
            <a href="<%= appLink %>" class="btn btn-app">
                <i class="fa-solid fa-rocket"></i> Launch Zoom App
            </a>

            <!-- SECONDARY ACTION: BROWSER -->
            <a href="<%= browserLink %>" class="btn btn-browser" target="_blank">
                <i class="fa-solid fa-globe"></i> Join via Web Browser
            </a>

            <div class="divider">Digital Credentials</div>

            <!-- MANUAL INFO -->
            <div class="info-grid">
                <div class="info-box" onclick="copyText('<%= meetingId %>', this)">
                    <span class="info-label">Meeting ID</span>
                    <span class="info-value"><%= meetingId %></span>
                    <i class="fa-regular fa-copy copy-icon"></i>
                    <div class="tooltip">COPIED</div>
                </div>
                <div class="info-box" onclick="copyText('<%= password %>', this)">
                    <span class="info-label">Password</span>
                    <span class="info-value"><%= password %></span>
                    <i class="fa-regular fa-copy copy-icon"></i>
                    <div class="tooltip">COPIED</div>
                </div>
            </div>

            <div class="footer">
                <i class="fa-solid fa-shield-halved"></i> 256-bit End-to-End Encryption Enabled
            </div>
        </div>
    </div>

    <script>
        function copyText(text, el) {
            navigator.clipboard.writeText(text).then(() => {
                el.classList.add('copied');
                setTimeout(() => el.classList.remove('copied'), 2000);
            });
        }

        // Automatic redirection attempt (Optional: launches app automatically if available)
        // window.location.href = "<%= appLink %>";
    </script>
</body>
</html>
